# Import required classes and functions from Flask
from flask import Flask, request, redirect, url_for, session, Response


# Create the Flask application object
app = Flask(__name__)


# Secret key is required for session security (used to encrypt session cookies)
app.secret_key = "supersecret"


# Define route for the home page and allow both GET and POST methods
@app.route("/", methods=["GET", "POST"])


# Function that will run when user visits "/"
def home():


    # Check if request method is POST (means form was submitted)
    if request.method == "POST":


        # Get username value from the submitted form
        username = request.form.get("username")


        # Get password value from the submitted form
        password = request.form.get("password")


        # Check if username and password match predefined credentials
        if username == "admin" and password == "1234":


            # Store the logged-in user in session (browser cookie storage)
            session["user"] = username


            # Redirect user to the welcome page
            return redirect(url_for("welcome"))


        else:
            # If login fails return a plain text response
            return Response("Invalid credentials", mimetype="text/plain")


    # If request method is GET, show the login form
    return '''
        <h2>Login Page</h2>

        <!-- HTML form to collect username and password -->
        <form method="POST">

            <!-- Username input field -->
            Username: <input type="text" name="username"><br>

            <!-- Password input field -->
            Password: <input type="password" name="password"><br>

            <!-- Submit button -->
            <input type="submit" value="Login">

        </form>
    '''


# Define route for welcome page
@app.route("/welcome")


# Function that runs when user visits "/welcome"
def welcome():


    # Check if user exists in session (means user logged in)
    if "user" in session:


        # Display welcome message with username stored in session
        return f'''
        <h2>Welcome, {session['user']}!</h2>

        <!-- Logout link -->
        <a href="{url_for('logout')}">Logout</a>
        '''


    else:
        # If user is not logged in redirect to login page
        return redirect(url_for("home"))


# Define route for logout
@app.route("/logout")


# Function to log the user out
def logout():


    # Remove user from session dictionary
    session.pop("user", None)


    # Redirect user back to login page
    return redirect(url_for("home"))


# Main entry point of the application
if __name__ == "__main__":


    # Run Flask development server with debug mode enabled
    app.run(debug=True)

