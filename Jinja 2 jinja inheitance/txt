3️⃣ feedback.html (Feedback Form Page)

This page extends base.html.

{% extends "base.html" %}  <!-- inherit layout from base.html -->

<!-- Replace title block -->
{% block title %} Feedback Form {% endblock %}

<!-- Replace content block -->
{% block content %}

    <!-- Page heading -->
    <h2>Send Us a Feedback Message</h2>

    <!-- Form sends data to /feedback route -->
    <form method="POST" action="/feedback">

        <!-- Username input -->
        <label for="username">Name:</label>

        <!-- name="username" connects with request.form.get("username") -->
        <input type="text"
               name="username"
               id="username"
               placeholder="Enter your username">

        <br><br>

        <!-- Message label -->
        <label for="message">Message:</label><br>

        <!-- Textarea for message -->
        <!-- name="message" connects with request.form.get("message") -->
        <textarea id="message"
                  name="message"
                  rows="5"
                  cols="40"
                  placeholder="Enter your message here"></textarea>

        <br><br>

        <!-- Submit button -->
        <input type="submit" value="Submit Feedback">

    </form>

{% endblock %}
...............................................................................
4️⃣ thankyou.html (Result Page)

This page shows the submitted data.

{% extends "base.html" %}  <!-- inherit layout -->

<!-- Page title -->
{% block title %} Thank You {% endblock %}

<!-- Page content -->
{% block content %}

    <!-- Display user name using Jinja2 -->
    <h2>Thank You {{ user }}!</h2>

    <p>For Your Feedback,</p>

    <!-- Display message -->
    <blockquote>
        {{ message }}
    </blockquote>

    <!-- Link back to feedback page -->
    <a href="/feedback">Return to Home</a>

{% endblock %}
